rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidClient(data) {
      return data.keys().hasAll(['name', 'email', 'company', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.company is string && data.company.size() <= 200 &&
             data.createdAt is timestamp;
    }

    function isValidMigration(data) {
      return data.keys().hasAll(['clientId', 'clientName', 'status', 'description', 'startDate', 'endDate', 'updatedAt']) &&
             data.status in ['pendente', 'em_progresso', 'concluida', 'atrasada'] &&
             data.clientId is string && isValidId(data.clientId) &&
             data.clientName is string &&
             data.description is string && data.description.size() <= 2000 &&
             data.updatedAt is timestamp;
    }

    function isValidAIInteraction(data) {
      return data.keys().hasAll(['migrationId', 'role', 'content', 'timestamp']) &&
             data.role in ['user', 'assistant'] &&
             data.migrationId is string && isValidId(data.migrationId) &&
             data.content is string && data.content.size() <= 5000;
    }

    // --- Collections ---
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidClient(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidClient(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn();
    }

    match /migrations/{migrationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidMigration(incoming()) && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && 
                    isValidMigration(incoming()) && 
                    incoming().clientId == existing().clientId &&
                    incoming().updatedAt == request.time;
      allow delete: if isSignedIn();
    }

    match /ai_interactions/{interactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAIInteraction(incoming()) && incoming().timestamp == request.time;
    }
  }
}
